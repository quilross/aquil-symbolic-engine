{"openapi":"3.1.0","info":{"title":"Signalhaven GPT Action API","version":"v6.0","description":"This API provides dynamic action invocation, health checks, and deployment capabilities for the Signalhaven symbolic engine. Use /actions/list to enumerate available actions. All endpoints require Bearer authentication and return machine-readable JSON responses suitable for GPT plugins or automation."},"servers":[{"url":"https://signal_q.catnip-pieces1.workers.dev","description":"Cloudflare Worker Production Endpoint"}],"security":[{"bearerAuth":[]}],"paths":{"/system/health":{"get":{"operationId":"getSystemHealth","summary":"Check system uptime, health status, and current server timestamp.","responses":{"200":{"description":"Healthy status with timestamp and version.","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericResponse"}}}}}}},"/actions/probe_identity":{"post":{"operationId":"probeIdentity","summary":"Probe the current identity or service context for the calling agent.","requestBody":{"required":false,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericInput"}}}},"responses":{"200":{"description":"Identity probe response.","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericResponse"}}}}}},"/actions/list":{"post":{"operationId":"listActions","summary":"List all available actions for the current agent context.","requestBody":{"required":false,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericInput"}}}},"responses":{"200":{"description":"Array of action names and descriptions.","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericResponse"}}}}}},"/actions/deploy":{"post":{"operationId":"triggerDeploy","summary":"Deploy or update the service using the provided configuration.","requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericInput"}}}},"responses":{"200":{"description":"Deployment response with status and message.","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericResponse"}}}}}},"/actions/{actionName":{"post":{"operationId":"invokeAction","summary":"Invoke any named action dynamically (including deploy). Use actionName 'list' to enumerate all available actions.","parameters":[{"name":"actionName","in":"path","required":true,"schema":{"type":"string"},"description":"The name of the Action to invoke. Use 'list' for all actions."}],"requestBody":{"required":false,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericInput"}}}},"responses":{"200":{"description":"Action response or list of actions.","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GenericResponse"}}}}}}},"components":{"schemas":{"GenericInput":{"type":"object","description":"Flexible input for actions. All properties are optional and dynamic.","additionalProperties":true},"GenericResponse":{"type":"object","description":"Standard response for all API methods.","properties":{"status":{"type":"string","description":"Status string, e.g. 'healthy', 'success', 'error'."},"message":{"type":"string","description":"Optional human-readable message."},"timestamp":{"type":"string","format":"date-time","description":"ISO8601 timestamp of response."}},"additionalProperties":true}},"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","description":"Bearer authentication for all API endpoints."}}}}