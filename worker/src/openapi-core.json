{
  "openapi": "3.1.0",
  "info": {
    "title": "Signal Q - Core Transcendence Agent",
    "version": "2.0.0",
    "description": "Essential Signal Q autonomous agent endpoints for CustomGPT integration. Core functionality across 4 creative lineages (THROATCRAFT, ARK, LUNACRAFT, Somatic) with AI-enhanced decision making."
  },
  "servers": [
    {
      "url": "https://signal_q.catnip-pieces1.workers.dev",
      "description": "Production Cloudflare Worker"
    }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/system/health": {
      "get": {
        "operationId": "getSystemHealth",
        "summary": "System health check",
        "responses": {
          "200": { "description": "System health status" }
        }
      }
    },
    "/agent-suggestions": {
      "get": {
        "operationId": "getAgentSuggestions",
        "summary": "AI autonomous suggestions based on patterns",
        "responses": {
          "200": { "description": "Agent suggestions" }
        }
      }
    },
    "/protocols/aquil-probe": {
      "post": {
        "operationId": "activateAquilProbe",
        "summary": "Activate AQUIL Probe with AI decision making",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "context": { "type": "string" },
                  "readiness": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Probe activation result" }
        }
      }
    },
    "/gene-key-guidance": {
      "get": {
        "operationId": "getGeneKeyGuidance",
        "summary": "Gene Key guidance for current state",
