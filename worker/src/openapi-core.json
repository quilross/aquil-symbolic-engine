          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "intensity": { "type": "number" },
                  "clarity": { "type": "boolean" }
                },
                "required": ["intensity"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Emotional wave analysis" }
        }
      }
    },
    "/manifestor-initiation": {
