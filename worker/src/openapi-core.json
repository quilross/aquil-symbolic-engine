{
  "openapi": "3.1.0",
  "info": {
    "title": "Signalhaven GPT Action API",
    "version": "v6.0",
    "description": "Symbolic and somatic GPT Action endpoints for use in the AQUIL/ARK framework."
  },
  "servers": [
    { "url": "https://signal_q.catnip-pieces1.workers.dev" }
  ],
  "paths": {
    "/system/health": {
      "get": {
        "operationId": "getSystemHealth",
        "summary": "Check system uptime and timestamp.",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/protocols/aquil-probe": {
      "post": {
        "operationId": "activateAquilProbe",
        "summary": "Run system-wide probe for protocol readiness.",
        "requestBody": { "required": false },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/throatcraft/voice-emergence": {
      "post": {
        "operationId": "getVoiceEmergenceProtocol",
        "summary": "Retrieve custom voice activation sequence.",
        "requestBody": { "required": false },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/ritual/gift-instinct-trigger": {
      "post": {
        "operationId": "triggerGiftInstinct",
        "summary": "Trigger symbolic gifting logic based on appreciation context.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "target": { "type": "string" },
                  "emotionalContext": { "type": "string" }
                },
                "required": ["target", "emotionalContext"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gift suggestion with symbolic context",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "gift": { "type": "string" },
                    "why": { "type": "string" },
                    "ritual": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {}
}
