{
  "openapi": "3.1.0",
  "info": {
    "title": "Signalhaven GPT Action API",
    "version": "v6.0",
    "description": "Unlimited Actions via dynamic /actions/{actionName} endpoint. See /actions/list for available actions. You can deploy directly via /actions/deploy."
  },
  "servers": [
    {
      "url": "https://signal_q.catnip-pieces1.workers.dev"
    }
  ],
  "paths": {
    "/system/health": {
      "get": {
        "operationId": "getSystemHealth",
        "summary": "Check system uptime and timestamp.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericResponse"
                }
              }
            }
          }
        }
      }
    },
    "/actions/{actionName}": {
      "post": {
        "operationId": "invokeAction",
        "summary": "Invoke any named Action dynamically, including deploy.",
        "parameters": [
          {
            "name": "actionName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the Action to invoke. Use 'list' to enumerate all available actions."
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenericInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action response or list of actions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenericInput": {
        "type": "object",
        "additionalProperties": true
      },
      "GenericResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}