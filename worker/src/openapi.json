                    "activityRecommendations": { "type": "array", "items": { "type": "string" } },
                    "dailyRhythm": { "type": "object" },
                    "currentAdvice": { "type": "string" },
                    "nextTransition": { "type": "string" },
                    "personalFactors": { "type": "object" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
