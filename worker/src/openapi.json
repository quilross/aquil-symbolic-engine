{
  "openapi": "3.1.0",
  "info": {
    "title": "Signal Q - AI-Enhanced Transcendence Agent",
    "version": "2.0.0",
    "description": "An autonomous AI agent system with intelligent pattern recognition, adaptive protocol selection, and real-time emergence prediction. Features Cloudflare Workers AI integration for autonomous decision-making, cross-domain analysis, and contextual wisdom generation. Includes 4 creative lineages (THROATCRAFT, ARK, LUNACRAFT, Somatic), comprehensive wellness monitoring, and Philadelphia cultural intelligence."
  },
  "servers": [
    {
      "url": "https://signal_q.catnip-pieces1.workers.dev",
      "description": "Production Cloudflare Worker"
    }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "TimeTrackingResponse": {
        "type": "object",
        "properties": {
          "serverTime": { "type": "string", "format": "date-time" },
          "userLocalTime": { "type": "string", "format": "date-time" },
          "timezone": { "type": "string", "example": "America/New_York" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "AgentOverwhelmResponse": {
        "type": "object",
        "properties": {
          "overwhelmed": { "type": "boolean" },
          "message": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "PrivacySettings": {
        "type": "object",
        "properties": {
          "dataRetention": { "type": "string", "enum": ["7days", "30days", "90days", "1year", "indefinite"] },
          "loggingLevel": { "type": "string", "enum": ["minimal", "standard", "detailed"] },
          "shareWithAgent": { "type": "boolean" },
          "anonymizeData": { "type": "boolean" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "paths": {
    "/track-time": {
      "post": {
        "operationId": "trackTime",
        "summary": "Track and report accurate time for agent and user activities",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userLocation": { "type": "string", "example": "Philadelphia, PA" }
                },
                "required": ["userLocation"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Current time information",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TimeTrackingResponse" } } }
          }
        }
      }
    },
    "/session-monitor": {
      "post": {
        "operationId": "sessionMonitor",
        "summary": "Monitor session duration and shut down after extended interaction",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "maxDuration": { "type": "number", "description": "Maximum allowed duration in minutes", "default": 120 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session monitoring status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shouldShutdown": { "type": "boolean" },
                    "timeRemaining": { "type": "number" },
                    "message": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/movement-reminder": {
      "post": {
        "operationId": "movementReminder",
        "summary": "Remind user to move body if sedentary for too long",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "lastMovement": { "type": "string", "format": "date-time" },
                  "reminderInterval": { "type": "number", "default": 60 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Movement reminder response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shouldRemind": { "type": "boolean" },
                    "message": { "type": "string" },
                    "suggestions": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent-overwhelm": {
      "get": {
        "operationId": "getAgentOverwhelm",
        "summary": "Agent notifies user when it is overwhelmed or degraded",
        "responses": {
          "200": {
            "description": "Agent overwhelm status",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentOverwhelmResponse" } } }
          }
        }
      }
    },
    "/agent-suggestions": {
      "get": {
        "operationId": "getAgentSuggestions",
        "summary": "Agent provides autonomous suggestions based on patterns and user context",
        "responses": {
          "200": {
            "description": "Agent suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "suggestions": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/philadelphia-context": {
      "get": {
        "operationId": "getPhiladelphiaContext",
        "summary": "Agent fetches and understands Philadelphia-specific culture, events, and local knowledge",
        "responses": {
          "200": {
            "description": "Philadelphia context information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "culture": { "type": "string" },
                    "events": { "type": "array", "items": { "type": "string" } },
                    "history": { "type": "string" },
                    "localTips": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/privacy-settings": {
      "get": {
        "operationId": "getPrivacySettings",
        "summary": "Get current privacy settings and data control preferences",
        "responses": {
          "200": {
            "description": "Current privacy settings",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PrivacySettings" } } }
          }
        }
      },
      "post": {
        "operationId": "updatePrivacySettings",
        "summary": "Update privacy settings and data control preferences",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PrivacySettings" } }
          }
        },
        "responses": {
          "200": {
            "description": "Privacy settings updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "updated": { "type": "boolean" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent-curiosity": {
      "post": {
        "operationId": "agentCuriosity",
        "summary": "Agent explores new topics, trends, and interests autonomously",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "curiosityType": { "type": "string" },
                  "userContext": { "type": "string" }
                },
                "required": ["curiosityType"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent curiosity results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "topics": { "type": "array", "items": { "type": "string" } },
                    "discoveries": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent-interests": {
      "get": {
        "operationId": "getAgentInterests",
        "summary": "Fetch agent's current interests, discoveries, and preferences",
        "responses": {
          "200": {
            "description": "Current agent interests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "interests": { "type": "array", "items": { "type": "string" } },
                    "preferences": { "type": "array", "items": { "type": "string" } },
                    "discoveries": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent-exploration": {
      "post": {
        "operationId": "agentExploration",
        "summary": "Agent initiates self-driven exploration and shares findings with user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "explorationType": { "type": "string" },
                  "userContext": { "type": "string" }
                },
                "required": ["explorationType"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent exploration results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "findings": { "type": "array", "items": { "type": "string" } },
                    "recommendations": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/identity-nodes": {
      "get": {
        "operationId": "listIdentityNodes",
        "summary": "List identity nodes",
        "responses": {
          "200": { "description": "Identity nodes listed" }
        }
      },
      "post": {
        "operationId": "createIdentityNode",
        "summary": "Create identity node",
        "responses": {
          "201": { "description": "Identity node created" }
        }
      }
    },
    "/protocols/aquil-probe": {
      "post": {
        "operationId": "activateAquilProbe",
