        }
      }
    },
    "/logs": {
      "get": {
        "operationId": "getLogs",
        "summary": "Fetch logs",
        "responses": {
          "200": { "description": "Logs retrieved" }
        }
      }
    },
    "/reset": {
      "post": {
        "operationId": "reset",
        "summary": "Reset user",
        "responses": {
          "200": { "description": "User reset completed" }
        }
      }
    },
    "/patterns/cross-domain": {
      "get": {
        "operationId": "getCrossDomainPatterns",
        "summary": "AI-powered analysis of patterns across emotional, creative, recovery, and social domains",
        "description": "Uses AI to analyze cross-domain patterns and generate intelligent insights about correlations, emerging patterns, and adaptive recommendations.",
        "responses": {
          "200": {
            "description": "Cross-domain pattern analysis with AI insights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "correlations": { "type": "object", "description": "Statistical correlations between domains" },
                    "emergingPatterns": { "type": "array", "items": { "type": "string" }, "description": "AI-detected emerging patterns" },
                    "predictiveSignals": { "type": "object", "description": "Early warning signals for different outcomes" },
                    "aiGeneratedInsights": { "type": "string", "description": "AI-generated deep insights" },
                    "adaptiveRecommendations": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/learning/adaptive-protocols": {
      "post": {
        "operationId": "getAdaptiveProtocols",
        "summary": "AI-powered protocol selection based on current context and goals",
        "description": "Uses AI to analyze context and recommend optimal protocols with customized steps and reasoning.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currentContext": { "type": "string", "description": "Description of current situation" },
                  "energyLevel": { "type": "string", "enum": ["very_low", "low", "medium", "high", "peak"] },
                  "timeAvailable": { "type": "string", "description": "Available time for protocol" },
                  "primaryGoal": { "type": "string", "description": "Main objective or goal" }
                },
                "required": ["currentContext", "energyLevel"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI-selected adaptive protocol with reasoning",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "selectedProtocol": { "type": "string" },
                    "adaptationReason": { "type": "string", "description": "AI reasoning for selection" },
                    "steps": { "type": "array", "items": { "type": "string" } },
                    "estimatedDuration": { "type": "string" },
                    "energyRequirement": { "type": "string" },
                    "expectedOutcomes": { "type": "array", "items": { "type": "string" } },
                    "fallbackOptions": { "type": "array", "items": { "type": "string" } },
                    "aiEnhanced": { "type": "boolean" },
                    "contextualWisdom": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/insights/emergence-prediction": {
      "get": {
        "operationId": "getEmergencePrediction",
        "summary": "AI-powered prediction of creative emergence and breakthrough moments",
        "description": "Uses AI to analyze patterns and predict optimal timing for breakthroughs, creative emergence, and significant insights.",
        "responses": {
          "200": {
            "description": "AI-enhanced emergence prediction with timeline and insights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "creativeProbability": { "type": "number", "minimum": 0, "maximum": 1 },
                    "breakthroughWindow": { "type": "string" },
                    "optimalConditions": { "type": "array", "items": { "type": "string" } },
                    "preparationSuggestions": { "type": "array", "items": { "type": "string" } },
                    "aiInsights": { "type": "string", "description": "AI-generated insights about emergence patterns" },
                    "aiPredictions": { "type": "object", "description": "AI-specific predictions" },
                    "timeline": {
                      "type": "object",
                      "properties": {
                        "next_24_hours": { "type": "string" },
                        "next_week": { "type": "string" },
                        "next_month": { "type": "string" }
                      }
                    },
                    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                    "factors": { "type": "array", "items": { "type": "string" } },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
