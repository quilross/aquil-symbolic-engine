    "/narratives/generate": {
      "post": {
        "operationId": "generateNarrative",
        "summary": "Generate narrative",
        "responses": {
          "200": { "description": "Narrative generated" }
        }
      }
    },
    "/transition-maps/{id}": {
      "get": {
        "operationId": "getSymbolicMap",
        "summary": "Get symbolic map",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Symbolic map retrieved" }
        }
      }
    },
    "/ritual-actions/trigger": {
      "post": {
        "operationId": "triggerRitualAction",
        "summary": "Trigger ritual",
        "responses": {
          "200": { "description": "Ritual triggered" }
        }
      }
    },
    "/friction-ratings": {
      "post": {
        "operationId": "recordFrictionRating",
        "summary": "Record friction rating",
