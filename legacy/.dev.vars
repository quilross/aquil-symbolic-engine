# Development environment variables for Wrangler
# These are loaded automatically by `npx wrangler dev`

# Development API tokens (use secure secrets in production)
SIGNALQ_API_TOKEN=dev-placeholder
SIGNALQ_ADMIN_TOKEN=dev-admin-placeholder
LOG_LEVEL=info
NODE_ENV=development

# Version information (can be set by CI/CD)
# GIT_SHA=local-development
# BUILD_TIME=2025-01-01T00:00:00.000Z