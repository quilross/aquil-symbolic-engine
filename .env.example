# Environment Variables for Local Development
# Copy this file to .env and fill in your actual values

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
SIGNAL_KV_ID=your_kv_namespace_id_here

# API Tokens (generate secure random values)
API_TOKEN_USER=sq_live_your_user_token_here
API_TOKEN_ADMIN=sq_admin_your_admin_token_here

# Worker Configuration
WORKER_NAME=signal_q
BASE_URL=https://signal_q.catnip-pieces1.workers.dev

# Note: .env files should never be committed to version control
# These values should match your GitHub Secrets configuration