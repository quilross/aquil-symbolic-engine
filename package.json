{
  "name": "signal-q",
  "version": "2.1.0",
  "description": "Signal Q - Autonomous Transcendence Agent API",
  "main": "worker/src/index.js",
  "type": "module",
  "scripts": {
    "test": "./test-runner.sh",
    "dev": "npx wrangler dev --remote --port 8787",
    "dev:fallback": "node scripts/wrangler-fallback.js dev",
    "deploy": "npx wrangler deploy",
    "secret-scan": "node scripts/secret-scan.cjs",
    "secret-scan:install": "node scripts/secret-scan.cjs install",
    "validate": "npm run secret-scan && npm audit",
    "build": "echo 'Validation build - checking worker syntax' && cd worker && node -c src/index.js && echo '✅ Worker syntax is valid'",
    "lint": "npm audit --audit-level moderate",
    "demo:sdk": "node sdk/demo.cjs"
  },
  "keywords": [
    "cloudflare-workers",
    "api",
    "transcendence-agent"
  ],
  "author": "quilross",
  "license": "MIT",
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@apidevtools/swagger-cli": "^4.0.4"
  }
}
